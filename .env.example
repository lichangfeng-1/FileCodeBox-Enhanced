# ============================================================
# FileCodeBox 前后端分离版 - 环境变量配置模板
#
# 使用方式：
#   1. 复制本文件为 .env:  cp .env.example .env
#   2. 修改下面的密码和密钥为随机值
#   3. docker compose up --build -d
#
# 生成随机密钥：
#   python3 -c "import secrets; print(secrets.token_urlsafe(24))"  # 数据库密码
#   python3 -c "import secrets; print(secrets.token_urlsafe(48))"  # JWT 密钥
#   python3 -c "import secrets; print(secrets.token_urlsafe(16))"  # 管理员密码
#   或: openssl rand -base64 32
# ============================================================

# ===== 端口配置 =====
FRONTEND_PORT=40157
BACKEND_PORT=12345

# ===== 数据库配置 =====
# 可选值: postgresql / mysql / sqlite
DB_TYPE=postgresql
DB_HOST=fcb-postgres
DB_PORT=5432
DB_NAME=filecodebox
DB_USER=fcb
DB_PASSWORD=your_random_db_password_here

# ===== 安全配置 =====
# JWT 签名密钥（用于管理员登录令牌签名，泄露会导致会话伪造）
JWT_SECRET=your_random_jwt_secret_here_at_least_32_chars
# 管理员密码（首次初始化时使用，登录后可在后台修改）
ADMIN_PASSWORD=your_admin_password_here

# ===== PostgreSQL 容器 =====
# 宿主机映射端口（仅调试用，生产环境建议注释掉）
# POSTGRES_PORT=5432

# ===== 数据持久化 =====
# 默认使用 Docker 存储卷（注释掉下方两行即可）
# 使用本地目录持久化（推荐生产环境）：
DATA_DIR=/home/FileCodeBox/data
PG_DATA_DIR=/home/FileCodeBox/pgdata
# 容器内数据目录（需与 docker-compose volumes 挂载点一致，一般无需修改）
# FCB_DATA_DIR=/app/data

# ===== 构建镜像源（国内用户取消注释加速构建，国外用户留空即可）=====
# APT_MIRROR=mirrors.aliyun.com
# PIP_MIRROR=https://pypi.tuna.tsinghua.edu.cn/simple
# NPM_REGISTRY=https://registry.npmmirror.com
